<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Altın Dokunuş · Bu Muydu Sistemi?</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --teal-dark: #060f0f;
  --teal-mid: #0a2020;
  --teal-accent: #0d3535;
  --teal-border: #1a5050;
  --gold: #F5A623;
  --gold-dim: #8a5a08;
  --white: #F0F0E8;
  --muted: #5a8888;
  --red: #b42828;
}

html, body {
  height: 100%; width: 100%;
  background: var(--teal-dark);
  font-family: 'Lora', Georgia, serif;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  user-select: none;
}

.progress {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  background: var(--gold);
  transition: width 0.4s cubic-bezier(.4,0,.2,1);
  z-index: 100;
}

.brand {
  position: fixed;
  top: 16px; left: 20px;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 2px;
  z-index: 100;
}

.counter {
  position: fixed;
  top: 16px; right: 20px;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 2px;
  z-index: 100;
}

.stage {
  position: relative;
  width: min(90vw, 420px);
  aspect-ratio: 1050 / 1350;
}

/* PNG image cards */
.card-img {
  position: absolute;
  inset: 0;
  border-radius: 12px;
  overflow: hidden;
  opacity: 0;
  transform: translateX(60px) scale(0.97);
  transition: opacity 0.4s cubic-bezier(.4,0,.2,1), transform 0.4s cubic-bezier(.4,0,.2,1);
  pointer-events: none;
  box-shadow: 0 20px 70px rgba(0,0,0,0.75);
  cursor: pointer;
}
.card-img.active {
  opacity: 1;
  transform: none;
  pointer-events: all;
}
.card-img.exit {
  opacity: 0;
  transform: translateX(-60px) scale(0.97);
}
.card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  -webkit-user-drag: none;
}

/* HTML puzzle cards */
.card-html {
  position: absolute;
  inset: 0;
  border-radius: 12px;
  overflow: hidden;
  opacity: 0;
  transform: translateX(60px) scale(0.97);
  transition: opacity 0.4s cubic-bezier(.4,0,.2,1), transform 0.4s cubic-bezier(.4,0,.2,1);
  pointer-events: none;
  box-shadow: 0 20px 70px rgba(0,0,0,0.75);
  background: var(--teal-dark);
  display: flex;
  flex-direction: column;
  padding: 5% 6%;
}
.card-html.active {
  opacity: 1;
  transform: none;
  pointer-events: all;
}
.card-html.exit {
  opacity: 0;
  transform: translateX(-60px) scale(0.97);
}

/* Card internals — responsive via em/% */
.c-sep { display: flex; align-items: center; gap: 8px; margin-bottom: 3%; }
.c-sep-line { width: 32px; height: 2px; background: var(--gold); flex-shrink: 0; }
.c-cat { font-size: clamp(8px, 1.4vmin, 13px); color: var(--muted); letter-spacing: 2px; font-style: normal; }

.c-label { font-size: clamp(9px, 1.5vmin, 14px); color: var(--muted); margin-bottom: 2%; letter-spacing: 1px; }

.c-headline {
  font-size: clamp(14px, 3.2vmin, 30px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.25;
  margin-bottom: 2%;
}
.c-italic {
  font-size: clamp(13px, 2.8vmin, 26px);
  font-style: italic;
  color: var(--gold);
  line-height: 1.3;
  margin-bottom: 3%;
}
.c-divider {
  height: 1px;
  background: var(--teal-border);
  margin: 3% 0;
}

/* Answer reveal box */
.c-answer-box {
  background: var(--teal-accent);
  border: 1px solid var(--teal-border);
  border-radius: 6px;
  padding: 3% 4%;
  margin-bottom: 3%;
  font-size: clamp(10px, 1.8vmin, 16px);
}
.c-answer-box .label { color: var(--gold); font-weight: 700; margin-bottom: 4px; }
.c-answer-box .text { color: var(--white); font-style: italic; }
.c-answer-box .sub { color: var(--muted); font-size: 0.85em; margin-top: 4px; }

/* Quote */
.c-quote {
  font-size: clamp(13px, 2.6vmin, 24px);
  font-style: italic;
  color: var(--white);
  line-height: 1.35;
  margin-bottom: 3%;
  padding-left: 3%;
  border-left: 2px solid var(--gold-dim);
}

/* Options */
.c-options { display: flex; flex-direction: column; gap: 2%; flex: 1; }
.c-opt {
  display: flex;
  align-items: center;
  gap: 4%;
  padding: 3% 4%;
  background: #0a2828;
  border: 1px solid var(--teal-border);
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, transform 0.15s;
  flex: 1;
}
.c-opt:hover { background: #0e3535; border-color: var(--gold-dim); }
.c-opt.correct {
  background: #0a3020;
  border-color: #2a8a50;
  animation: pulse-correct 0.4s ease;
}
.c-opt.wrong {
  background: #2a0a0a;
  border-color: var(--red);
  animation: shake 0.35s ease;
}
.c-opt.disabled { cursor: default; pointer-events: none; }

@keyframes pulse-correct {
  0% { transform: scale(1); }
  50% { transform: scale(1.02); }
  100% { transform: scale(1); }
}
@keyframes shake {
  0%,100% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  75% { transform: translateX(6px); }
}

.opt-letter {
  font-size: clamp(14px, 2.8vmin, 26px);
  font-weight: 700;
  color: var(--gold);
  min-width: 1.2em;
  flex-shrink: 0;
}
.opt-text {
  font-size: clamp(10px, 2vmin, 18px);
  font-style: italic;
  color: var(--white);
  line-height: 1.3;
}
.opt-icon {
  margin-left: auto;
  font-size: clamp(12px, 2vmin, 18px);
  opacity: 0;
  transition: opacity 0.2s;
}
.c-opt.correct .opt-icon { opacity: 1; color: #4CAF50; }
.c-opt.wrong .opt-icon { opacity: 1; color: var(--red); }

/* Hint */
.c-hint {
  font-size: clamp(8px, 1.4vmin, 13px);
  color: var(--muted);
  font-style: italic;
  margin-bottom: 2%;
  padding: 2% 3%;
  border-left: 2px solid var(--gold-dim);
}

/* Next prompt */
.c-next {
  font-size: clamp(8px, 1.4vmin, 12px);
  color: var(--muted);
  font-style: italic;
  margin-top: auto;
  padding-top: 2%;
}

/* Brand bottom */
.c-brand {
  display: flex;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 2%;
  font-size: clamp(8px, 1.3vmin, 11px);
  color: var(--muted);
  letter-spacing: 1px;
}

/* Blank fill */
.c-blank {
  display: inline-block;
  border-bottom: 2px solid var(--gold-dim);
  min-width: 80px;
  color: var(--gold-dim);
  font-style: normal;
  font-weight: 700;
  letter-spacing: 4px;
  padding: 0 4px;
}
.c-blank.filled {
  color: var(--gold);
  border-color: var(--gold);
}

/* Nav */
.nav {
  position: fixed;
  bottom: 20px;
  display: flex;
  gap: 16px;
  align-items: center;
  z-index: 100;
}
.nav-btn {
  background: var(--teal-mid);
  border: 1px solid #1a5050;
  color: var(--gold);
  width: 42px; height: 42px;
  border-radius: 50%;
  font-size: 18px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s, transform 0.15s;
}
.nav-btn:hover { background: #0d3535; transform: scale(1.08); }
.nav-btn:disabled { opacity: 0.2; cursor: default; transform: none; }
.dots { display: flex; gap: 6px; align-items: center; }
.dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--muted);
  transition: background 0.3s, transform 0.3s;
  cursor: pointer;
}
.dot.active { background: var(--gold); transform: scale(1.5); }

/* CTA */
.cta {
  position: fixed;
  bottom: 74px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--gold);
  color: #060f0f;
  font-family: 'Lora', serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 1px;
  padding: 10px 24px;
  border-radius: 4px;
  border: none;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s;
  text-decoration: none;
  white-space: nowrap;
}
.cta.visible { opacity: 1; pointer-events: all; }
</style>
</head>
<body>

<div class="progress" id="progress"></div>
<div class="brand">BU MUYDU SİSTEMİ?</div>
<div class="counter" id="counter">1 / 7</div>

<div class="stage" id="stage">

<!-- KART 1 — PNG -->
<div class="card-img active" id="card-1" onclick="go(1)">
  <img src="data:image/png;base64," alt="Kart 1" draggable="false">
</div>

<!-- KART 2 — Eksik kelime + A/B/C -->
<div class="card-html" id="card-2">
  <div class="c-sep"><div class="c-sep-line"></div><span class="c-cat">BULMACA · MİTOLOJİ</span></div>
  <div class="c-label">Boşluğu doldur:</div>
  <div class="c-headline">
    Midas'ın laneti, kızına<br>
    <span class="c-blank" id="blank2">_ _ _ _ _ _</span> anda başladı.
  </div>
  <div class="c-hint">💡 İpucu: Güç sarhoşluğu sınır tanımaz, ta ki en değerlisini kaybedene kadar.</div>
  <div class="c-divider"></div>
  <div class="c-label">Hangisi doğru?</div>
  <div class="c-options">
    <div class="c-opt" onclick="answer(this, false, 2)">
      <span class="opt-letter">A</span>
      <span class="opt-text">dokunduğu</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, true, 2)">
      <span class="opt-letter">B</span>
      <span class="opt-text">sarıldığı</span>
      <span class="opt-icon">✓</span>
    </div>
    <div class="c-opt" onclick="answer(this, false, 2)">
      <span class="opt-letter">C</span>
      <span class="opt-text">gördüğü</span>
      <span class="opt-icon">✗</span>
    </div>
  </div>
  <div class="c-next">→ Cevap bir sonraki kartta açıklanıyor.</div>
  <div class="c-brand"><span>BU MUYDU SİSTEMİ?</span><span>2 / 7</span></div>
</div>

<!-- KART 3 — Cevap + A/B soru -->
<div class="card-html" id="card-3">
  <div class="c-sep"><div class="c-sep-line"></div><span class="c-cat">CEVAP & YENİ SORU · JEOPOLİTİK</span></div>
  <div class="c-answer-box">
    <div class="label">✓ Cevap: B — sarıldığı</div>
    <div class="text">Kızına sarıldığında her şey değişti. Güç, sevgiye dokunduğunda lanete dönüştü.</div>
  </div>
  <div class="c-quote">"Küba zaten son nefeslerini veriyor."<br><small style="color:var(--muted);font-size:0.8em">— Trump, geçen hafta</small></div>
  <div class="c-divider"></div>
  <div class="c-label">Şimdi düşün:</div>
  <div class="c-headline">Bir ülkenin "son nefesini" bekleyip sahip çıkmak...</div>
  <div class="c-options">
    <div class="c-opt" onclick="answer(this, false, 3)">
      <span class="opt-letter">A</span>
      <span class="opt-text">Akıllıca strateji</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, true, 3)">
      <span class="opt-letter">B</span>
      <span class="opt-text">Modern sömürgecilik</span>
      <span class="opt-icon">✓</span>
    </div>
  </div>
  <div class="c-next">→ Cevap bir sonraki kartta.</div>
  <div class="c-brand"><span>BU MUYDU SİSTEMİ?</span><span>3 / 7</span></div>
</div>

<!-- KART 4 — Şifre çöz -->
<div class="card-html" id="card-4">
  <div class="c-sep"><div class="c-sep-line"></div><span class="c-cat">ŞİFRE · STRATEJİ & GÜÇ</span></div>
  <div class="c-answer-box">
    <div class="label">✓ Cevap: B — Modern sömürgecilik</div>
    <div class="sub">Hafızalar kalıcıdır. Kim yanında durdu, kim uzaktan izledi — unutulmaz.</div>
  </div>
  <div class="c-label">Bu cümleyi tamamla:</div>
  <div class="c-headline">
    Abluka bir <span class="c-blank" id="blank4a">_ _ _ _ _</span> değil,<br>
    bir <span class="c-blank" id="blank4b">_ _ _ _ _ _ _</span>'dır.
  </div>
  <div class="c-hint">💡 Florida kıyısından 145 km · Petrol yok, ışık yok · Masa üstünde çıkar değil...</div>
  <div class="c-options">
    <div class="c-opt" onclick="answer(this, true, 4)">
      <span class="opt-letter">A</span>
      <span class="opt-text">araç / mesaj</span>
      <span class="opt-icon">✓</span>
    </div>
    <div class="c-opt" onclick="answer(this, false, 4)">
      <span class="opt-letter">B</span>
      <span class="opt-text">tehdit / güç</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, false, 4)">
      <span class="opt-letter">C</span>
      <span class="opt-text">taktik / strateji</span>
      <span class="opt-icon">✗</span>
    </div>
  </div>
  <div class="c-next">→ Cevap bir sonraki kartta.</div>
  <div class="c-brand"><span>BU MUYDU SİSTEMİ?</span><span>4 / 7</span></div>
</div>

<!-- KART 5 — Kim kazanıyor? -->
<div class="card-html" id="card-5">
  <div class="c-sep"><div class="c-sep-line"></div><span class="c-cat">OY VER · COĞRAFYA & HAFIZA</span></div>
  <div class="c-answer-box">
    <div class="label">✓ Cevap: A — araç / mesaj</div>
    <div class="sub">Her abluka bir şey söyler. Ama kime?</div>
  </div>
  <div class="c-label">Bu masada kim kazanıyor? Oyu ver:</div>
  <div class="c-options">
    <div class="c-opt" onclick="answer(this, false, 5)">
      <span class="opt-letter">◎</span>
      <span class="opt-text">Havana'daki aileler</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, false, 5)">
      <span class="opt-letter">◎</span>
      <span class="opt-text">Washington stratejistleri</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, false, 5)">
      <span class="opt-letter">◎</span>
      <span class="opt-text">İzleyen Türkiye</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, true, 5)">
      <span class="opt-letter">◎</span>
      <span class="opt-text">Hiçbiri — hafıza kazanır</span>
      <span class="opt-icon">✓</span>
    </div>
  </div>
  <div class="c-divider"></div>
  <div class="c-italic">Güçlü olan neden sürekli hatırlatma ihtiyacı duyuyor?</div>
  <div class="c-next">→ Son soru bir sonraki kartta.</div>
  <div class="c-brand"><span>BU MUYDU SİSTEMİ?</span><span>5 / 7</span></div>
</div>

<!-- KART 6 — Liderlik testi -->
<div class="card-html" id="card-6">
  <div class="c-sep"><div class="c-sep-line"></div><span class="c-cat">LİDERLİK TESTİ · KARAR ANI</span></div>
  <div class="c-answer-box">
    <div class="label">✓ Cevap: Hiçbiri — hafıza kazanır.</div>
    <div class="sub">Güçlü olan korkmaz. Korkusu olan güç gösterir.</div>
  </div>
  <div class="c-divider"></div>
  <div class="c-headline">Rakibin zayıfladı.</div>
  <div class="c-italic">Sen ne yaparsın?</div>
  <div class="c-options">
    <div class="c-opt" onclick="answer(this, false, 6)">
      <span class="opt-letter">A</span>
      <span class="opt-text">Beklersin. Zayıflarken sahip çıkarsın.</span>
      <span class="opt-icon">✗</span>
    </div>
    <div class="c-opt" onclick="answer(this, true, 6)">
      <span class="opt-letter">B</span>
      <span class="opt-text">Masayı büyütürsün. Birlikte kazanırsın.</span>
      <span class="opt-icon">✓</span>
    </div>
  </div>
  <div class="c-divider"></div>
  <div class="c-headline" style="font-size:clamp(13px,2.8vmin,26px)">Hafızalar kalıcıdır.</div>
  <div class="c-italic" style="font-size:clamp(11px,2.2vmin,20px)">Midas da öyle düşünmüştü.</div>
  <div class="c-next">→ Son kart seni bekliyor.</div>
  <div class="c-brand"><span>BU MUYDU SİSTEMİ?</span><span>6 / 7</span></div>
</div>

<!-- KART 7 — PNG -->
<div class="card-img" id="card-7">
  <img src="data:image/png;base64," alt="Kart 7" draggable="false">
</div>

</div><!-- /stage -->

<a class="cta" id="cta" href="https://linkedin.com" target="_blank">LinkedIn'de Devam Et →</a>

<div class="nav">
  <button class="nav-btn" id="prev" onclick="go(-1)" disabled>&#8592;</button>
  <div class="dots" id="dots"></div>
  <button class="nav-btn" id="next" onclick="go(1)">&#8594;</button>
</div>

<script>
let current = 1;
const total = 7;
const answered = {};

// Build dots
const dotsEl = document.getElementById('dots');
for (let i = 1; i <= total; i++) {
  const d = document.createElement('div');
  d.className = 'dot' + (i === 1 ? ' active' : '');
  d.onclick = () => goTo(i);
  dotsEl.appendChild(d);
}

function answer(el, correct, cardNum) {
  if (answered[cardNum]) return;
  answered[cardNum] = true;

  const opts = el.parentElement.querySelectorAll('.c-opt');
  opts.forEach(o => o.classList.add('disabled'));

  el.classList.add(correct ? 'correct' : 'wrong');

  // Find correct option and highlight if wrong answer picked
  if (!correct) {
    opts.forEach(o => {
      if (o.onclick && o.onclick.toString().includes('true')) {
        o.classList.add('correct');
      }
    });
  }

  // Fill blanks
  if (cardNum === 2) {
    const b = document.getElementById('blank2');
    if (b) { b.textContent = 'sarıldığı'; b.classList.add('filled'); }
  }
  if (cardNum === 4) {
    const a = document.getElementById('blank4a');
    const b = document.getElementById('blank4b');
    if (a) { a.textContent = 'araç'; a.classList.add('filled'); }
    if (b) { b.textContent = 'mesaj'; b.classList.add('filled'); }
  }

  // Auto-advance after 1.6s
  setTimeout(() => go(1), 1600);
}

function update() {
  document.getElementById('progress').style.width = (current / total * 100) + '%';
  document.getElementById('counter').textContent = current + ' / ' + total;
  document.getElementById('prev').disabled = current === 1;
  document.getElementById('next').disabled = current === total;
  document.querySelectorAll('.dot').forEach((d, i) => {
    d.classList.toggle('active', i + 1 === current);
  });
  const cta = document.getElementById('cta');
  current === total ? cta.classList.add('visible') : cta.classList.remove('visible');
}

function goTo(n) {
  if (n < 1 || n > total || n === current) return;
  const prev = document.getElementById('card-' + current);
  prev.classList.remove('active');
  prev.classList.add('exit');
  setTimeout(() => prev.classList.remove('exit'), 400);
  current = n;
  document.getElementById('card-' + current).classList.add('active');
  update();
}

function go(dir) { goTo(current + dir); }

// Click on PNG cards to advance
document.getElementById('card-1').addEventListener('click', () => go(1));
document.getElementById('card-7').addEventListener('click', () => {});

// Keyboard
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === ' ') go(1);
  if (e.key === 'ArrowLeft') go(-1);
});

// Swipe
let startX = 0;
document.getElementById('stage').addEventListener('touchstart', e => {
  startX = e.touches[0].clientX;
}, { passive: true });
document.getElementById('stage').addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - startX;
  if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
});

update();
</script>
</body>
</html>
