  .film-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 4vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .film-title em {
    font-style: italic;
    color: var(--green);
  }

  .film-meta {
    display: flex;
    gap: 1.5rem;
    margin: 1.5rem 0;
    flex-wrap: wrap;
  }

  .film-meta span {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .film-meta strong {
    color: var(--green);
    font-weight: 500;
  }

  .film-intro {
    font-size: 1.1rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.7;
    border-left: 3px solid var(--green);
    padding-left: 1.2rem;
    margin-top: 1rem;
  }

  /* ARTICLE */
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 4rem;
  }

  .article p {
    margin-bottom: 1.8rem;
    color: var(--ink);
  }

  .article h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--green);
    margin: 3rem 0 1rem;
    line-height: 1.2;
  }

  .article h2 em { font-style: italic; }

  .article blockquote {
    background: var(--green-pale);
    border-left: 4px solid var(--green);
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    border-radius: 0 4px 4px 0;
  }

  .article blockquote p {
    font-style: italic;
    color: var(--green);
    margin: 0;
    font-size: 1.05rem;
  }

  .divider {
    text-align: center;
    margin: 3rem 0;
    color: var(--green);
    letter-spacing: 0.5em;
    font-size: 0.8rem;
  }

  /* RATING */
  .rating-box {
    background: var(--green);
    color: var(--white);
    padding: 3rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
