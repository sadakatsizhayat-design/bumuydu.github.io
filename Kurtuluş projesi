  .rating-score {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    font-weight: 900;
    line-height: 1;
  }

  .rating-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-style: italic;
    max-width: 400px;
    line-height: 1.4;
    opacity: 0.9;
  }

  /* FOOTER */
  footer {
    background: var(--green);
    color: var(--white);
    padding: 2.5rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
