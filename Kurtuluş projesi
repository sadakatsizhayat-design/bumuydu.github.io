  .hero {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: auto 1fr;
    min-height: auto;
    gap: 2rem;
    padding: 2rem;
    background: var(--bg);
  }

  .hero-image {
    position: relative;
    overflow: hidden;
    background: #1a2a25;
    max-width: 400px;
    margin: 2rem 0 2rem 2rem;
    border-radius: 4px;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.85;
  }

  .hero-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--white);
    border-left: 1px solid var(--border);
